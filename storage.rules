rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Projects folder: read by anyone, upload/delete by authenticated admins
    match /projects/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // General access: allow read for anyone, write for authenticated users
    match /{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
